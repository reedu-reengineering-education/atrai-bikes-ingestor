# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_NAME=sensor_data
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432
# Full URL used by the ingestor and migration runner
DATABASE_URL=postgresql://postgres:password@localhost:5432/sensor_data

# ── Ingestion ─────────────────────────────────────────────────────────────────
GROUPTAGS=heilbronn,lauds_26
DEFAULT_START_DATE=2026-07-01

# ── Analysis ──────────────────────────────────────────────────────────────────
INT_API_TOKEN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
