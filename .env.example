# ── Database ──────────────────────────────────────────────────────────────────
# Used by the app, migrations, and analysis processes.
# The docker-compose files map DATABASE_* → POSTGRES_* for the pg container.
DATABASE_NAME=atrai_bikes
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme
DATABASE_HOST=localhost          # use "postgis" when running inside Docker Compose
DATABASE_PORT=5432
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/atrai_bikes

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Comma-separated OpenSenseMap grouptags to ingest
GROUPTAGS=heilbronn
DEFAULT_START_DATE=2024-01-01

# ── Analysis ──────────────────────────────────────────────────────────────────
# Secret required by POST /analyze
INT_API_TOKEN=changeme_strong_token

# ── Production extras ─────────────────────────────────────────────────────────
GITHUB_REPOSITORY=reedu-reengineering-education/atrai-bikes-ingestor
APP_PORT=8000
MARTIN_PORT=3000
SYNC_INTERVAL_HOURS=6

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
