# Database Configuration
# PostgreSQL connection string for PostGIS database
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/sensor_data

# OpenSenseMap API Configuration
# Base URL for OpenSenseMap API (default: https://api.opensensemap.org)
OPENSENSEMAP_API_URL=https://api.opensensemap.org

# Base URL for OpenSenseMap Archive (default: https://archive.opensensemap.org)
OPENSENSEMAP_ARCHIVE_URL=https://archive.opensensemap.org

# Grouptags to filter sensor boxes (comma-separated, default: atrai)
# Example: atrai,lauds_26
GROUPTAGS=atrai

# Logging Configuration
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sync Configuration
# Default start date for boxes with no sync history (YYYY-MM-DD)
DEFAULT_START_DATE=2024-01-01

# Maximum number of retries for API requests
MAX_RETRIES=3

# Initial delay for exponential backoff (seconds)
INITIAL_RETRY_DELAY=1.0

# Maximum delay for exponential backoff (seconds)
MAX_RETRY_DELAY=60.0
