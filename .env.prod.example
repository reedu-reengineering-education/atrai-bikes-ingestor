# Production Environment Configuration
# Copy this file to .env.prod and fill in the actual values
# IMPORTANT: Never commit .env.prod to version control!

# ============================================
# Database Configuration (REQUIRED)
# ============================================
# PostgreSQL database name
POSTGRES_DB=sensor_data

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password (REQUIRED - must be strong in production)
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# ============================================
# OpenSenseMap API Configuration
# ============================================
# Base URL for OpenSenseMap API
OPENSENSEMAP_API_URL=https://api.opensensemap.org

# Base URL for OpenSenseMap Archive
OPENSENSEMAP_ARCHIVE_URL=https://archive.opensensemap.org

# Grouptags to filter sensor boxes (comma-separated)
# Example: atrai,lauds_26
GROUPTAGS=atrai

# ============================================
# Logging Configuration
# ============================================
# Log level: INFO (production), WARNING (minimal), ERROR (critical only)
LOG_LEVEL=INFO

# ============================================
# Sync Configuration
# ============================================
# Default start date for boxes with no sync history (YYYY-MM-DD)
DEFAULT_START_DATE=2024-01-01

# Maximum number of retries for API requests
MAX_RETRIES=3

# Initial delay for exponential backoff (seconds)
INITIAL_RETRY_DELAY=1.0

# Maximum delay for exponential backoff (seconds)
MAX_RETRY_DELAY=60.0

# ============================================
# Production Deployment Notes
# ============================================
# 1. Generate strong passwords for POSTGRES_PASSWORD
# 2. Consider using Docker secrets or a secrets manager for sensitive values
# 3. Review resource limits in docker-compose.prod.yml
# 4. Set up regular database backups
# 5. Monitor logs and set up alerting
# 6. Use LOG_LEVEL=INFO or WARNING in production
# 7. Set up a cron job for scheduled sync execution
